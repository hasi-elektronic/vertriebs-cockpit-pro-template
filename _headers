/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  X-Robots-Tag: noindex, nofollow
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: https://*.tile.openstreetmap.org https://news.google.com; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/leads-geo.json
  Cache-Control: public, max-age=600

/karte
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/dashboard
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/news
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/admin
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400

/sw.js
  Content-Type: application/javascript
  Cache-Control: no-cache

/icon-192.png
  Cache-Control: public, max-age=604800

/icon-512.png
  Cache-Control: public, max-age=604800
